---
// Andrii Maksymenko – portfolio (single page)
const email = "andrii.maksymenko.dev@gmail.com";
const mailto = `mailto:${email}?subject=Junior%20Software%20Developer%20role&body=Hi%20Andrii%2C`;

const projects = [
  {
    name: "Expense Tracker API",
    tag: "Production REST backend on Azure",
    categories: ["Backend"],
    live: "https://expense-tracker-api-andrii.azurewebsites.net",
    source: "https://github.com/defoltbl/expense-tracker-api",
    body:
      "A REST API in Kotlin and Ktor with JWT authentication, BCrypt hashing, refresh tokens, rate limiting and a SendGrid password-reset flow, with per-user data isolation enforced at the query level. Containerized with Docker and deployed to Azure App Service with managed PostgreSQL, Application Insights and a GitHub Actions CI pipeline.",
    stack: ["Kotlin", "Ktor", "PostgreSQL", "Docker", "Azure", "GitHub Actions", "JWT"],
  },
  {
    name: "HYBRIDEA",
    tag: "Hybrid RL/IL game-AI agent · MSc thesis",
    categories: ["AI/ML", "Games"],
    source: "https://github.com/defoltbl/ms-pacman-hybridea",
    body:
      "A hybrid model combining Behavioral Cloning and PPO to train NPC agents in a Ms. Pac-Man environment, benchmarked against five baselines (DQN, PPO, A2C, Monte Carlo, BC). Built around a Conv2D Actor–Critic network over 12-channel stacked frames, with a full training, evaluation and checkpointing pipeline. HYBRIDEA achieved the best overall results of all agents tested.",
    stack: ["Python", "PyTorch", "OpenAI Gym", "Reinforcement Learning", "Behavioral Cloning"],
  },
  {
    name: "Personal Finance Tracker",
    tag: "Android app · Kotlin & Firebase",
    categories: ["Mobile"],
    source: "https://github.com/defoltbl/personal-finance-tracker",
    body:
      "A full-featured personal finance app with account and authentication handling, transaction logging and budgeting, backed by Firebase Realtime Database and Firebase Auth. Structured with Fragment-based navigation and MVVM architecture for maintainability.",
    stack: ["Kotlin", "Android SDK", "Firebase", "MVVM"],
  },
  {
    name: "Story-Driven Indie Game",
    tag: "2D game in Python · BSc thesis",
    categories: ["Games"],
    source: "https://github.com/defoltbl/story-driven-indie-game",
    body:
      "A 2D story-driven indie game featuring farming, combat and an in-game economy, with save/load via Pickle. Covers full game-loop design, map loading through PyTmx and state persistence.",
    stack: ["Python", "Pygame", "PyTmx"],
  },
];

const projectFilters = ["All", "Backend", "AI/ML", "Mobile", "Games"];

const skills = [
  { group: "Backend & Cloud", items: ["Kotlin", "Ktor", "REST APIs", "JWT", "BCrypt", "Docker", "Azure", "PostgreSQL", "GitHub Actions"] },
  { group: "Languages", items: ["Python", "Kotlin", "SQL"] },
  { group: "AI / Machine Learning", items: ["PyTorch", "OpenAI Gym", "PPO", "DQN", "A2C", "Behavioral Cloning", "CNNs"] },
  { group: "Mobile / Android", items: ["Android SDK", "Firebase", "MVVM"] },
  { group: "Databases & Tools", items: ["PostgreSQL", "PL/pgSQL", "Git", "Linux"] },
];

const experience = [
  { role: "Pre-Diploma Practice", org: "TOV NVO “Diskret”", when: "Nov 2025 – Jan 2026 · Remote", body: "Applied research and implementation for the MSc thesis project (hybrid RL/IL game AI): literature review, model implementation and experimental evaluation." },
  { role: "Production Practice", org: "PP NVP “Kare”", when: "Feb 2024 – Mar 2024 · Remote", body: "Practical training at an electronics R&D company; completed an individual technical assignment analyzing and extending an indie game project – architecture, design patterns and framework selection." },
  { role: "Production Practice", org: "NGO “Educational Fund KIPSOLID”", when: "2023 · Remote", body: "Researched assistive computer-vision technologies for visually impaired users – object detection and text recognition – as part of an applied research assignment." },
];

const education = [
  { degree: "MSc, Computer Science – with Honours", school: "Odesa Polytechnic National University", when: "2024 – 2026", body: "Thesis: hybrid RL/IL agents for NPC behaviour in video games." },
  { degree: "BSc, Computer Science", school: "Odesa Polytechnic National University", when: "2020 – 2024", body: "Recognized as equivalent to a Czech Bachelor's in Informatika (ČVUT Prague, 2026)." },
  { degree: "Certificate – Creating Mobile Apps with Android", school: "Anhalt University of Applied Sciences / DAAD", when: "2023", body: "92/100 (Excellent) · 120h / 4 ECTS · Credential ID CMAA/2023S29." },
];

const publications = [
  { title: "Hybrid Training of an Intelligent Agent for Efficient Maze Navigation in Ms. Pac-Man", venue: "Modern Inventions, Technologies and Ideas (19th Int. Scientific-Practical Conference), Sofia, Bulgaria", when: "May 2026", note: "Sole author · proceedings pp. 54–56", url: "https://eu-conf.com/wp-content/uploads/2026/03/MODERN-INVENTIONS-TECHNOLOGIES-AND-IDEAS-PROBLEMS-THEORIES-AND-CHALLENGES.pdf" },
  { title: "Modeling Intelligent Behavior of Characters in Video Games to Improve Level-Completion Speed", venue: "Modern Information Technologies 2025 (15th Int. Scientific Conference), Odesa", when: "May 2025", note: "Co-authored with O. Halchonkov", url: "https://drive.google.com/file/d/1zi1TabIH7iso1-SW__9ntZ_LG0glE4Wa/view" },
];

const sections = [
  ["about", "About"],
  ["projects", "Projects"],
  ["skills", "Skills"],
  ["experience", "Experience"],
  ["education", "Education"],
  ["publications", "Publications"],
  ["contact", "Contact"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Andrii Maksymenko – Junior Software Developer (Backend, Cloud & AI/ML)</title>
    <meta name="description" content="Junior Software Developer in backend, cloud and AI/ML. Deployed a Kotlin/Ktor REST API on Azure and published reinforcement-learning research at two international conferences." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://andrii-maksymenko.com" />
    <meta property="og:title" content="Andrii Maksymenko – Junior Software Developer" />
    <meta property="og:description" content="Junior Software Developer in backend, cloud and AI/ML. Deployed a Kotlin/Ktor REST API on Azure and published reinforcement-learning research at two international conferences." />
    <meta property="og:image" content="https://andrii-maksymenko.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://andrii-maksymenko.com/og.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline src="/theme-init.js"></script>
  </head>

  <body>
    <a class="skip" href="#main">Skip to content</a>

    <header class="topbar">
      <a class="brand" href="#top">AM</a>
      <div class="nav-right">
        <nav aria-label="Primary">
          {sections.map(([id, label]) => <a href={`#${id}`}>{label}</a>)}
        </nav>
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
          <svg class="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4.2"/>
            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>
          </svg>
        </button>
      </div>
    </header>

    <main id="main">
      <!-- HERO -->
      <section class="hero" id="top">
        <h1>Junior Software Developer – backend &amp; cloud, with a research background in AI/ML.</h1>
        <p class="lede">
          MSc Computer Science (Honours) · published at two international AI conferences.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href="#projects">View projects</a>
          <a class="btn" href="/AndriiMaksymenko_CV_EN.pdf" target="_blank" rel="noopener">Download CV</a>
          <a class="btn" href="https://github.com/defoltbl" target="_blank" rel="noopener">GitHub</a>
          <a class="btn" href="https://www.linkedin.com/in/andrii-maksymenko-83628932a/" target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </section>

      <!-- ABOUT -->
      <section id="about" class="section">
        <div class="section-head"><span class="kicker">about</span></div>
        <div class="prose">
          <p>
            I'm a Junior Software Developer with an MSc in Computer Science (with Honours) from
            Odesa Polytechnic National University. My Bachelor's degree is recognized as equivalent
            to a Czech Bachelor's in Informatika (ČVUT Prague, 2026).
          </p>
          <p>
            I work across Python, Kotlin and SQL, with a focus on backend, cloud and AI/ML
            engineering. I recently built and deployed a production-style REST API in Kotlin and
            Ktor on Microsoft Azure – JWT auth, BCrypt, refresh tokens, rate limiting, PostgreSQL,
            Docker and a GitHub Actions CI pipeline. My MSc thesis, HYBRIDEA, designed a hybrid
            Behavioral Cloning + PPO agent for NPC behaviour in Ms. Pac-Man, published and presented
            at international conferences in Odesa (2025) and Sofia, Bulgaria (2026).
          </p>
          <p>
            I'm comfortable working independently across the full build cycle – design,
            implementation, testing and cloud deployment. Native Ukrainian and Russian speaker, B2
            English, looking for my first full-time junior role.
          </p>
        </div>
      </section>

      <!-- PROJECTS -->
      <section id="projects" class="section">
        <div class="section-head"><span class="kicker">projects</span></div>
        <div class="filters" role="group" aria-label="Filter projects by category">
          {projectFilters.map((f, i) => (
            <button class="filter-btn" type="button" data-filter={f} aria-pressed={i === 0 ? "true" : "false"}>{f}</button>
          ))}
        </div>
        <div class="grid">
          {projects.map((p) => (
            <article class="card" data-categories={p.categories.join(",")}>
              <div class="card-head">
                <h3>{p.name}</h3>
                {p.live && <span class="status"><span class="dot"></span>Live on Azure</span>}
              </div>
              <p class="card-tag">{p.tag}</p>
              <p class="card-body">{p.body}</p>
              <ul class="stack">
                {p.stack.map((s) => <li>{s}</li>)}
              </ul>
              <div class="card-links">
                {p.live && <a href={p.live} target="_blank" rel="noopener">Live API ↗</a>}
                <a href={p.source} target="_blank" rel="noopener">Source ↗</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- SKILLS -->
      <section id="skills" class="section">
        <div class="section-head"><span class="kicker">skills</span></div>
        <div class="skills">
          {skills.map((s) => (
            <div class="skill-group">
              <h4>{s.group}</h4>
              <ul>
                {s.items.map((i) => <li>{i}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- EXPERIENCE -->
      <section id="experience" class="section">
        <div class="section-head"><span class="kicker">experience</span></div>
        <div class="timeline">
          {experience.map((e) => (
            <div class="entry">
              <div class="entry-meta">{e.when}</div>
              <div class="entry-body">
                <h3>{e.role} <span class="org">· {e.org}</span></h3>
                <p>{e.body}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- EDUCATION -->
      <section id="education" class="section">
        <div class="section-head"><span class="kicker">education</span></div>
        <div class="timeline">
          {education.map((e) => (
            <div class="entry">
              <div class="entry-meta">{e.when}</div>
              <div class="entry-body">
                <h3>{e.degree}</h3>
                <p class="org-line">{e.school}</p>
                <p>{e.body}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- PUBLICATIONS -->
      <section id="publications" class="section">
        <div class="section-head"><span class="kicker">publications</span></div>
        <div class="timeline">
          {publications.map((p) => (
            <div class="entry">
              <div class="entry-meta">{p.when}</div>
              <div class="entry-body">
                <h3>{p.title}</h3>
                <p class="org-line">{p.venue}</p>
                <p class="pub-note">{p.note}</p>
                <a class="inline-link" href={p.url} target="_blank" rel="noopener">Read publication ↗</a>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- CONTACT -->
      <section id="contact" class="section contact">
        <div class="section-head"><span class="kicker">contact</span></div>
        <h2>Open to junior software roles – on-site or hybrid in Prague, or remote.</h2>
        <p class="lede">The fastest way to reach me is by email.</p>
        <div class="cta-row">
          <a class="btn btn-primary" href={mailto}>Contact me</a>
          <a class="btn" href="https://www.linkedin.com/in/andrii-maksymenko-83628932a/" target="_blank" rel="noopener">LinkedIn</a>
          <a class="btn" href="https://github.com/defoltbl" target="_blank" rel="noopener">GitHub</a>
        </div>
        <p class="loc">Prague / Mladá Boleslav, Czech Republic</p>
      </section>
    </main>

    <footer>
      <span>© 2026 Andrii Maksymenko</span>
      <span class="built">Built with Astro</span>
    </footer>

    <style is:global>
      :root {
        --paper: #f7f8fa;
        --surface: #ffffff;
        --ink: #14181f;
        --muted: #5a6473;
        --text-soft: #3a4250;
        --accent: #2d5bff;
        --accent-deep: #1b3fb8;
        --line: #e4e7ec;
        --live: #16a34a;
        --topbar-bg: rgba(247, 248, 250, 0.82);
        --maxw: 1080px;
        --display: "Space Grotesk", system-ui, sans-serif;
        --body: "Inter", system-ui, sans-serif;
        --mono: "JetBrains Mono", ui-monospace, monospace;
      }

      :root[data-theme="dark"] {
        --paper: #0e1116;
        --surface: #161b22;
        --ink: #e6e9ee;
        --muted: #9aa4b2;
        --text-soft: #c2c9d4;
        --accent: #6e8dff;
        --accent-deep: #5b82ff;
        --line: #262c36;
        --live: #2ecc71;
        --topbar-bg: rgba(14, 17, 22, 0.82);
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; scroll-padding-top: 72px; }

      body {
        background: var(--paper);
        color: var(--ink);
        font-family: var(--body);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        transition: background 0.3s, color 0.3s;
      }

      a { color: inherit; }

      .skip {
        position: absolute; left: -999px; top: 0; z-index: 100;
        background: var(--ink); color: #fff; padding: 10px 16px; border-radius: 0 0 8px 0;
      }
      .skip:focus { left: 0; }

      /* ---------- Top bar ---------- */
      .topbar {
        position: sticky; top: 0; z-index: 50;
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px clamp(20px, 5vw, 48px);
        background: var(--paper);
        border-bottom: 1px solid var(--line);
        -webkit-transform: translateZ(0);
        transform: translateZ(0);
        isolation: isolate;
      }
      .nav-right { display: flex; align-items: center; gap: clamp(14px, 2.5vw, 28px); }
      .theme-toggle {
        background: var(--surface); border: 1.5px solid var(--line); border-radius: 9px;
        width: 38px; height: 38px; display: inline-grid; place-items: center; cursor: pointer;
        color: var(--ink); transition: border-color 0.15s, color 0.15s;
      }
      .theme-toggle:hover { border-color: var(--accent); color: var(--accent); }
      .theme-toggle .sun { display: none; }
      :root[data-theme="dark"] .theme-toggle .moon { display: none; }
      :root[data-theme="dark"] .theme-toggle .sun { display: block; }
      .brand {
        font-family: var(--mono); font-weight: 500; letter-spacing: 0.08em;
        text-decoration: none; border: 1.5px solid var(--ink); padding: 4px 9px; border-radius: 7px;
      }
      .topbar nav { display: flex; gap: clamp(12px, 2vw, 28px); }
      .topbar nav a {
        font-family: var(--mono); font-size: 0.82rem; text-decoration: none; color: var(--muted);
        transition: color 0.15s;
      }
      .topbar nav a:hover { color: var(--accent); }

      /* ---------- Layout ---------- */
      main { max-width: var(--maxw); margin: 0 auto; padding: 0 clamp(20px, 5vw, 48px); }
      .section { padding: clamp(56px, 9vw, 104px) 0; border-top: 1px solid var(--line); }

      .section-head {
        display: flex; align-items: center; gap: 16px; margin-bottom: 40px;
      }
      .kicker {
        font-family: var(--mono); font-size: 0.82rem; color: var(--accent);
        letter-spacing: 0.06em; margin: 0; display: inline-flex; align-items: center; gap: 11px;
        white-space: nowrap; text-transform: lowercase;
      }
      .kicker::before {
        content: ""; width: 9px; height: 9px; border-radius: 2px;
        background: var(--accent); transform: rotate(45deg);
      }
      .section-head::after {
        content: ""; flex: 1; height: 1px;
        background: linear-gradient(90deg, var(--line), transparent);
      }

      /* ---------- Hero ---------- */
      .hero { padding: clamp(72px, 13vw, 150px) 0 clamp(48px, 8vw, 90px); }
      .eyebrow {
        font-family: var(--mono); font-size: 0.84rem; color: var(--muted);
        letter-spacing: 0.02em; margin-bottom: 22px;
      }
      .hero h1 {
        font-family: var(--display); font-weight: 700;
        font-size: clamp(2rem, 5vw, 3.4rem); line-height: 1.08;
        letter-spacing: -0.02em; max-width: 20ch;
      }
      .hero h1, .contact h2 { text-wrap: balance; }
      .lede { color: var(--muted); font-size: clamp(1rem, 2vw, 1.18rem); margin-top: 22px; max-width: 52ch; }

      /* ---------- Buttons ---------- */
      .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 34px; }
      .btn {
        font-family: var(--mono); font-size: 0.86rem; text-decoration: none;
        padding: 11px 18px; border-radius: 9px; border: 1.5px solid var(--line);
        background: var(--surface); color: var(--ink);
        transition: border-color 0.15s, transform 0.15s, color 0.15s;
      }
      .btn:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }
      .btn-primary {
        background: var(--accent); color: #fff; border-color: var(--accent);
      }
      .btn-primary:hover { background: var(--accent-deep); border-color: var(--accent-deep); color: #fff; }

      /* ---------- About ---------- */
      .prose { max-width: 66ch; }
      .prose p { font-size: clamp(1rem, 2vw, 1.12rem); margin-bottom: 18px; }
      .prose p:last-child { margin-bottom: 0; }

      /* ---------- Projects ---------- */
      /* ---------- Project filters ---------- */
      .filters {
        display: flex; gap: 10px; margin-bottom: 30px;
        overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch;
        padding-bottom: 2px;
      }
      .filters::-webkit-scrollbar { display: none; }
      .filter-btn {
        font-family: var(--mono); font-size: 0.82rem; white-space: nowrap;
        padding: 8px 16px; border-radius: 999px; cursor: pointer;
        border: 1.5px solid var(--line); background: var(--surface); color: var(--muted);
        transition: border-color 0.15s, color 0.15s, background 0.15s;
      }
      .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
      .filter-btn[aria-pressed="true"] { background: var(--accent); border-color: var(--accent); color: #fff; }

      .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; }
      .card.is-hidden { opacity: 0; transform: translateY(18px) scale(0.97); pointer-events: none; }
      .card {
        background: var(--surface); border: 1px solid var(--line); border-radius: 16px;
        padding: 28px; display: flex; flex-direction: column;
        transition: opacity 0.3s ease, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.25s ease, border-color 0.25s ease;
      }
      .card:hover {
        transform: translateY(-4px); border-color: #d4d9e2;
        box-shadow: 0 14px 40px -22px rgba(20, 24, 31, 0.35);
      }
      .card-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
      .card h3 { font-family: var(--display); font-weight: 600; font-size: 1.28rem; letter-spacing: -0.01em; }
      .status {
        display: inline-flex; align-items: center; gap: 6px;
        font-family: var(--mono); font-size: 0.7rem; color: var(--live);
        white-space: nowrap;
      }
      .dot {
        width: 8px; height: 8px; border-radius: 50%; background: var(--live);
        box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.5); animation: pulse 2.4s infinite;
      }
      @keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.45); }
        70% { box-shadow: 0 0 0 7px rgba(22, 163, 74, 0); }
        100% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0); }
      }
      .card-tag { font-family: var(--mono); font-size: 0.78rem; color: var(--muted); margin: 8px 0 14px; }
      .card-body { color: var(--text-soft); font-size: 0.96rem; flex: 1; }
      .stack { list-style: none; display: flex; flex-wrap: wrap; gap: 7px; margin: 18px 0; }
      .stack li {
        font-family: var(--mono); font-size: 0.72rem; color: var(--muted);
        background: var(--paper); border: 1px solid var(--line); padding: 4px 9px; border-radius: 6px;
      }
      .card-links { display: flex; gap: 18px; }
      .card-links a {
        font-family: var(--mono); font-size: 0.82rem; font-weight: 500; color: var(--accent);
        text-decoration: none;
      }
      .card-links a:hover { text-decoration: underline; }

      /* ---------- Skills ---------- */
      .skills { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px 48px; max-width: 860px; }
      .skill-group h4 { font-family: var(--mono); font-weight: 500; font-size: 0.82rem; color: var(--muted); margin-bottom: 14px; }
      .skill-group ul { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; }
      .skill-group li {
        font-size: 0.88rem; background: var(--surface); border: 1px solid var(--line);
        padding: 6px 12px; border-radius: 8px;
      }

      /* ---------- Timeline (experience / education / publications) ---------- */
      .timeline { display: flex; flex-direction: column; gap: 36px; }
      .entry { display: grid; grid-template-columns: 200px 1fr; gap: 28px; }
      .entry-meta { font-family: var(--mono); font-size: 0.8rem; color: var(--muted); padding-top: 3px; }
      .entry-body h3 { font-family: var(--display); font-weight: 600; font-size: 1.12rem; }
      .entry-body .org { color: var(--muted); font-weight: 500; }
      .org-line { color: var(--muted); font-size: 0.92rem; margin-top: 2px; }
      .entry-body p { color: var(--text-soft); margin-top: 8px; max-width: 64ch; }
      .pub-note { font-family: var(--mono); font-size: 0.78rem; color: var(--muted) !important; }
      .inline-link {
        display: inline-block; margin-top: 10px; font-family: var(--mono); font-size: 0.82rem;
        color: var(--accent); text-decoration: none; font-weight: 500;
      }
      .inline-link:hover { text-decoration: underline; }

      /* ---------- Contact ---------- */
      .contact h2 { font-family: var(--display); font-weight: 700; font-size: clamp(1.5rem, 3.5vw, 2.3rem); letter-spacing: -0.02em; max-width: 18ch; }
      .contact .lede { margin-top: 14px; }
      .loc { font-family: var(--mono); font-size: 0.8rem; color: var(--muted); margin-top: 26px; }

      /* ---------- Footer ---------- */
      footer {
        max-width: var(--maxw); margin: 0 auto; padding: 32px clamp(20px, 5vw, 48px);
        border-top: 1px solid var(--line); display: flex; justify-content: space-between;
        font-family: var(--mono); font-size: 0.78rem; color: var(--muted);
      }

      /* ---------- Responsive ---------- */
      @media (max-width: 720px) {
        .topbar nav { display: none; }
        .grid, .skills { grid-template-columns: 1fr; }
        .entry { grid-template-columns: 1fr; gap: 8px; }
        .entry-meta { padding-top: 0; }
      }

      @media (prefers-reduced-motion: reduce) {
        * { animation: none !important; transition: none !important; scroll-behavior: auto !important; }
      }

      a:focus-visible, .btn:focus-visible {
        outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 4px;
      }
    </style>
    <script is:inline src="/theme-toggle.js"></script>
    <script is:inline src="/projects-filter.js"></script>
  </body>
</html>
